{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NewsJobRequest",
  "type": "object",
  "required": ["jobId", "requestedAt", "provider", "interestKeywords", "maxItemsPerSource", "dateRangeHours", "sources"],
  "properties": {
    "jobId": { "type": "string" },
    "requestedAt": { "type": "string", "format": "date-time" },
    "provider": { "type": "string", "enum": ["claude", "codex", "gemini", "opencode"] },
    "interestKeywords": { "type": "array", "items": { "type": "string" } },
    "maxItemsPerSource": { "type": "integer", "minimum": 1, "maximum": 50 },
    "dateRangeHours": { "type": "integer", "minimum": 1, "maximum": 168 },
    "outputDir": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "enabled"],
        "properties": {
          "type": { "type": "string", "enum": ["youtube", "google_news", "linkedin", "yozm_it"] },
          "enabled": { "type": "boolean" },
          "channelId": { "type": "string" },
          "keywords": { "type": "array", "items": { "type": "string" } },
          "profiles": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
