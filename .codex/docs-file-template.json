  "code_mappings": {
    "_help": "각 섹션의 항목은 '어떤 종류의 코드/리소스가 이 섹션 문서에 매핑되는가'를 설명한다. docs-config-sync 스킬이 이 설명을 보고 사용자의 실제 프로젝트 경로(path)를 채워준다. kind는 카테고리 식별자, description은 사람이 읽고 매핑할 수 있는 설명, examples는 project_type별 흔한 파일 패턴.",

    "3_system_design": [
      {
        "kind": "entry-point",
        "description": "앱 / 서버 진입점. 부트스트랩, 환경 초기화, 의존성 등록이 일어나는 단일 파일",
        "examples": {
          "desktop": "<App 이름>App.swift (@main + AppDelegate / ModelContainer 등록)",
          "mobile": "<App 이름>App.swift / Application.kt / MainActivity.kt / index.tsx",
          "web": "main.ts / server.ts / app.module.ts / pages/_app.tsx / next.config.js"
        }
      },
      {
        "kind": "global-state",
        "description": "전역 상태 객체. 앱 전체에서 공유되는 단일 출처 상태",
        "examples": {
          "desktop": "AppState.swift (@Observable / @MainActor)",
          "mobile": "Redux store / Zustand / ViewModel 루트",
          "web": "store/ (Redux / Zustand) / context/ (React)"
        }
      },
      {
        "kind": "domain-manager",
        "description": "도메인 매니저 / 서비스 / Use Case 폴더. 비즈니스 로직을 담는 클래스 모음",
        "examples": {
          "desktop": "Features/ 또는 Managers/ (final class @MainActor)",
          "mobile": "features/ / domain/ / usecases/",
          "web": "services/ / domain/ / use-cases/"
        }
      },
      {
        "kind": "utility",
        "description": "공용 유틸리티·헬퍼 (단축키 / 알림 / 토스트 / 로깅 등 cross-cutting concerns)",
        "examples": {
          "desktop": "Utilities/ (HotKeyManager / NotificationManager / ToastPanel)",
          "mobile": "utils/ / shared/",
          "web": "lib/ / utils/ / shared/"
        }
      },
      {
        "kind": "external-bridge",
        "description": "외부 프로세스 / 서비스 / sidecar 호출 책임 코드 (있으면)",
        "examples": {
          "desktop": "Services/ (sidecar Process 실행 / 외부 SDK 래퍼)",
